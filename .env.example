# API token for the gngn.my gateway (OpenAI-compatible endpoint).
# Under the hood this is a Minimax M2.7 family model.
MINIMAX_API_KEY=replace-me
MINIMAX_BASE_URL=https://api.gngn.my/v1

# Gateway-specific model name overrides. The app sends "opus-4-7" /
# "haiku-4-5" / "sonnet-4-6" by default; set these if your gateway needs
# different strings in its `model` field. Leave empty for passthrough.
GATEWAY_OPUS_MODEL=
GATEWAY_SONNET_MODEL=
GATEWAY_HAIKU_MODEL=
